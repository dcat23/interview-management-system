{
  "info": {
    "_postman_id": "ims-api-v1",
    "name": "Interview Management System API",
    "description": "API reference for the Interview Management System. Base URL: https://api.{domain}/v1\n\nAll endpoints require `Authorization: Bearer {accessToken}` unless marked public.\n\nUse the **Login** request first — it auto-populates `accessToken` and `refreshToken` collection variables via the test script.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl",      "value": "https://api.example.com/v1", "type": "string" },
    { "key": "accessToken",  "value": "",                            "type": "string" },
    { "key": "refreshToken", "value": "",                            "type": "string" },
    { "key": "userId",       "value": "",                            "type": "string" },
    { "key": "clientId",     "value": "",                            "type": "string" },
    { "key": "questionId",   "value": "",                            "type": "string" },
    { "key": "processId",    "value": "",                            "type": "string" },
    { "key": "sessionId",    "value": "",                            "type": "string" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"string\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "**Public** — no auth required.\n\nAuthenticate and receive tokens. The test script automatically stores `accessToken` and `refreshToken` into collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "**Public** — no auth required.\n\nRotate access token using a valid refresh token. The test script automatically stores the new `accessToken`."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/auth/logout?refreshToken={{refreshToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"],
              "query": [
                { "key": "refreshToken", "value": "{{refreshToken}}", "description": "Optional — invalidates the refresh token" }
              ]
            },
            "description": "Invalidate the current refresh token. Access token expires naturally after TTL.\n\n**Roles:** all\n\n**Response:** `204 No Content`"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users?isActive=true&page=0&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "role",     "value": "",     "description": "Filter by role (ADMIN | MARKETER | SUPPORTER | CANDIDATE)", "disabled": true },
                { "key": "isActive", "value": "true", "description": "Default true" },
                { "key": "page",     "value": "0",    "description": "Default 0 (zero-based)" },
                { "key": "limit",    "value": "20",   "description": "Default 20" }
              ]
            },
            "description": "List users with optional filters.\n\n**Roles:** admin"
          }
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('userId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"supersecret123!\",\n  \"role\": \"SUPPORTER\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Create a new user.\n\n`role` values: `CANDIDATE | MARKETER | SUPPORTER | ADMIN`\n\n**Roles:** admin\n\n**Response:** `201` — returns created user object. Test script stores `id` → `userId`."
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Get user by ID.\n\n**Roles:** admin, self (non-admin users may only fetch their own profile)"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"janedoe@example.com\",\n  \"role\": \"MARKETER\",\n  \"isActive\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Update user fields. All fields optional.\n\n**Roles:** admin\n\n**Response:** `200` — returns updated user object."
          }
        }
      ]
    },
