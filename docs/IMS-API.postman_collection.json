          }
        },
        {
          "name": "Get Question",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "{{questionId}}"]
            },
            "description": "Get a single question including version and authorship metadata.\n\n**Roles:** admin, marketer, supporter"
          }
        },
        {
          "name": "Update Question",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic\": \"Spring Boot\",\n  \"round\": \"Technical Screen\",\n  \"body\": \"Explain the difference between @Component and @Bean. Give examples of when to use each.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "{{questionId}}"]
            },
            "description": "Update question content. Always increments `version` on save. Previous version archived in `question_versions`. `updatedBy` set from JWT.\n\n**Roles:** admin\n\n**Response:** `200` — returns updated question object."
          }
        },
        {
          "name": "Delete Question (soft)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "{{questionId}}"]
            },
            "description": "Soft-delete a question. Sets `active = false`. The question remains in the database and linked to existing sessions.\n\n**Roles:** admin\n\n**Response:** `204 No Content`"
          }
        }
      ]
    },
    {
      "name": "Interview Processes",
      "item": [
