          "name": "List Questions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/questions?page=0&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["questions"],
              "query": [
                { "key": "clientId", "value": "", "description": "Filter by end client UUID", "disabled": true },
                { "key": "topic",    "value": "", "description": "Partial match on topic",    "disabled": true },
                { "key": "page",     "value": "0",  "description": "Default 0" },
                { "key": "limit",    "value": "20", "description": "Default 20" }
              ]
            },
            "description": "List active questions with optional filters.\n\n**Roles:** admin, marketer, supporter"
          }
        },
        {
          "name": "Create Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('questionId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
