              "query": [
                { "key": "page",  "value": "0" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "List interview processes.\n\nCandidates automatically see only their own processes. Admin/marketer see all.\n\n**Roles:** admin, marketer, candidate"
          }
        },
        {
          "name": "Create Process",
          "event": [
            {
              "listen": "test",
              "script": {
